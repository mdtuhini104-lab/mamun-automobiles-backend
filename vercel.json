{
  "version": 2,
  "builds": [
    {
      "src": "mamun-automobiles-backend/public/index.php",
      "use": "vercel-php@0.7.2"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/health",
      "dest": "/mamun-automobiles-backend/public/index.php"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "/mamun-automobiles-backend/public/index.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/mamun-automobiles-backend/public/index.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
