VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_URL=http://localhost:8000/api
VITE_REVERB_APP_KEY=mamun_erp_key
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Universal Realtime Feature Flags
VITE_ENABLE_REALTIME=true
VITE_ENABLE_POLLING_FALLBACK=true
VITE_BROADCAST_DRIVER=reverb # Options: pusher, reverb, none
VITE_POLLING_INTERVAL=30 # Base polling interval in seconds

# Pusher Configuration
VITE_PUSHER_APP_KEY=
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https
VITE_PUSHER_APP_CLUSTER=mt1
